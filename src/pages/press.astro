---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Press & Publications | Ella Maria Grosz - Contemporary Oil Painter" description="Press releases, publications, and media coverage of Ella Maria Grosz, contemporary oil painter featured in art journals and galleries.">

    <section class="portfolio-page">
        <div class="container">
            <h1>Press & Publications</h1>
            <p class="portfolio-intro">Featured in major art publications, interviews, and press releases showcasing Ella Maria Grosz's artistic practice and contemporary contributions to the oil painting landscape.</p>
            
            <div class="news-list">
                <article class="news-item">
                    <img data-src="./images/artist-studio.jpg" alt="Artist in studio" loading="lazy">
                    <div class="news-content">
                        <span class="category">Publication</span>
                        <h3>Featured in Art Quarterly Magazine</h3>
                        <p>An in-depth interview exploring Ella Maria Grosz's evolving artistic practice and the shift towards larger format canvases in her current series.</p>
                        <p class="date">September 2023 Issue</p>
                    </div>
                </article>

                <article class="news-item">
                    <img data-src="./images/art-gallery-exhibition.jpg" alt="Art gallery space" loading="lazy">
                    <div class="news-content">
                        <span class="category">Press Release</span>
                        <h3>Artist Selected for International Contemporary Art Fair</h3>
                        <p>Ella Maria Grosz has been selected to exhibit her latest works at the prestigious International Contemporary Art Fair, showcasing pieces from 2023-2024.</p>
                        <p class="date">October 2023</p>
                    </div>
                </article>

                <article class="news-item">
                    <img data-src="./images/oil-painting-detail.jpg" alt="Detail of oil painting" loading="lazy">
                    <div class="news-content">
                        <span class="category">Feature Article</span>
                        <h3>The Modern Painter: Profile on Contemporary Oil Techniques</h3>
                        <p>A comprehensive feature covering Ella Maria Grosz's methodology and the renaissance of traditional oil painting in contemporary art.</p>
                        <p class="date">August 2023</p>
                    </div>
                </article>

                <article class="news-item">
                    <img data-src="./images/og-image.jpg" alt="Studio work" loading="lazy">
                    <div class="news-content">
                        <span class="category">Interview</span>
                        <h3>Studio Visit: Exploring Light and Shadow with Ella Maria Grosz</h3>
                        <p>An exclusive studio visit and conversation about the artist's process, inspirations, and vision for the future of her artistic practice.</p>
                        <p class="date">July 2023</p>
                    </div>
                </article>
            </div>
        </div>
    </section>

</Layout>