---
import Layout from '../../layouts/Layout.astro';
import PaintingCard from '../../components/PaintingCard.astro';
import { locales, isLocale, type Locale } from '../../i18n/locales';
import { getMessages } from '../../i18n';
import { paintings } from '../../data/paintings';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang: langParam } = Astro.params;
if (!isLocale(langParam ?? '')) {
  return Astro.redirect('/en/portfolio');
}
const lang = langParam as Locale;
const m = getMessages(lang);

const hasMixed = paintings.some((p) => p.medium === 'mixed');
const hasRecent = paintings.some((p) => p.recent);
---

<Layout lang={lang} title={m.portfolioPage.title} description={m.portfolioPage.description}>

    <section id="portfolio" class="portfolio-page">
        <div class="container">
            <header class="page-head">
                <h1>{m.portfolioPage.heading}</h1>
                <p class="page-intro">{m.portfolioPage.intro}</p>
            </header>

            {paintings.length === 0 ? (
                <p class="empty-state">{m.portfolioPage.empty}</p>
            ) : (
                <>
                    <div class="filters" role="tablist">
                        <button class="filter-btn active" data-filter="all">{m.common.filterAll}</button>
                        <button class="filter-btn" data-filter="oil">{m.common.filterOil}</button>
                        {hasMixed && <button class="filter-btn" data-filter="mixed">{m.common.filterMixed}</button>}
                        {hasRecent && <button class="filter-btn" data-filter="recent">{m.common.filterRecent}</button>}
                    </div>
                    <div class="portfolio-grid">
                        {paintings.map((item, i) => (
                            <PaintingCard painting={item} lang={lang} loading={i < 4 ? 'eager' : 'lazy'} />
                        ))}
                    </div>
                </>
            )}
        </div>
    </section>

</Layout>
