---
import Layout from '../../layouts/Layout.astro';
import UpdateCard from '../../components/UpdateCard.astro';
import { locales, isLocale, type Locale } from '../../i18n/locales';
import { getMessages } from '../../i18n';
import { getUpdates } from '../../data/updates';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang: langParam } = Astro.params;
if (!isLocale(langParam ?? '')) {
  return Astro.redirect('/en/press');
}
const lang = langParam as Locale;
const m = getMessages(lang);
const items = getUpdates('press');
---

<Layout lang={lang} title={m.pressPage.title} description={m.pressPage.description}>

    <section class="portfolio-page">
        <div class="container">
            <header class="page-head">
                <h1>{m.pressPage.heading}</h1>
                <p class="page-intro">{m.pressPage.intro}</p>
            </header>

            {items.length === 0 ? (
                <p class="empty-state">{m.pressPage.empty}</p>
            ) : (
                <div class="news-list">
                    {items.map((entry) => (
                        <UpdateCard entry={entry} lang={lang} />
                    ))}
                </div>
            )}
        </div>
    </section>

</Layout>
