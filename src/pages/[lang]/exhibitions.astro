---
import Layout from '../../layouts/Layout.astro';
import { locales, isLocale, type Locale } from '../../i18n/locales';
import { getMessages } from '../../i18n';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang: langParam } = Astro.params;
if (!isLocale(langParam ?? '')) {
  return Astro.redirect('/en/exhibitions');
}
const lang = langParam as Locale;
const m = getMessages(lang);
---

<Layout lang={lang} title={m.exhibitionsPage.title} description={m.exhibitionsPage.description}>

    <section class="portfolio-page">
        <div class="container">
            <h1>{m.exhibitionsPage.heading}</h1>
            <p class="portfolio-intro">{m.exhibitionsPage.intro}</p>

            <div class="news-list">
                {m.exhibitionsPage.items.map((item) => (
                    <article class="news-item">
                        <img data-src={item.imageSrc} alt={item.imageAlt} loading="lazy">
                        <div class="news-content">
                            <span class="category">{item.category}</span>
                            <h3>{item.title}</h3>
                            <p>{item.excerpt}</p>
                            <p class="date">{item.date}</p>
                        </div>
                    </article>
                ))}
            </div>
        </div>
    </section>

</Layout>
