---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Exhibitions | Ella Maria Grosz - Contemporary Oil Painter" description="Exhibitions and gallery shows featuring Ella Maria Grosz's contemporary oil paintings. View upcoming and past exhibitions.">

    <section class="portfolio-page">
        <div class="container">
            <h1>Exhibitions</h1>
            <p class="portfolio-intro">Explore Ella Maria Grosz's exhibition history spanning gallery shows, institutions, and international art fairs showcasing her contemporary oil paintings.</p>
            
            <div class="news-list">
                <article class="news-item">
                    <img data-src="./images/art-gallery-exhibition.jpg" alt="Gallery exhibition space" loading="lazy">
                    <div class="news-content">
                        <span class="category">Current Exhibition</span>
                        <h3>The Modern Muse - Solo Exhibition at London Contemporary Gallery</h3>
                        <p>A major solo presentation exploring the intersection of traditional oil painting techniques and contemporary visual language through large-scale canvases.</p>
                        <p class="date">October 12 — November 20, 2024</p>
                    </div>
                </article>

                <article class="news-item">
                    <img data-src="./images/artist-studio.jpg" alt="Artist studio view" loading="lazy">
                    <div class="news-content">
                        <span class="category">Upcoming</span>
                        <h3>International Contemporary Art Fair - Amsterdam</h3>
                        <p>Ella Maria Grosz will present selected works from her 2023-2024 series at the prestigious international contemporary art fair.</p>
                        <p class="date">December 2024</p>
                    </div>
                </article>

                <article class="news-item">
                    <img data-src="./images/oil-painting-detail.jpg" alt="Oil painting detail" loading="lazy">
                    <div class="news-content">
                        <span class="category">Past Exhibition</span>
                        <h3>Substrata Series - Limited Edition Release</h3>
                        <p>A curated exhibition featuring the complete Substrata series with 25 hand-finished giclée prints and original oil studies.</p>
                        <p class="date">May — June 2024</p>
                    </div>
                </article>

                <article class="news-item">
                    <img data-src="./images/og-image.jpg" alt="Exhibition opening" loading="lazy">
                    <div class="news-content">
                        <span class="category">Past Exhibition</span>
                        <h3>Emerging Voices in Contemporary Painting</h3>
                        <p>Group exhibition highlighting contemporary painters redefining the boundaries of traditional oil painting through innovative techniques and concepts.</p>
                        <p class="date">February — March 2024</p>
                    </div>
                </article>
            </div>
        </div>
    </section>

</Layout>