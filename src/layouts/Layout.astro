---
import '../styles/style.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Ella Maria Grosz is a contemporary oil painter based in London, specializing in layered oil paintings that capture fleeting moments of light and shadow.", image = "/images/og-image.jpg" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <!-- SEO Meta Tags -->
    <meta name="description" content={description}>
    <meta name="keywords" content="oil painter, contemporary art, Ella Maria Grosz, London artist, oil paintings, mixed media, art portfolio">
    <meta name="author" content="Ella Maria Grosz">

    <!-- Open Graph Tags -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content="Explore the portfolio of Ella Maria Grosz, a contemporary oil painter capturing fleeting moments through classical technique.">
    <meta property="og:image" content={image}>
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://ellamariagrosz.github.io">

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:image" content={image}>

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" type="image/x-icon">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>
    <header class="header">
        <div class="container">
            <div class="logo">
                <a href="/"><h1>Ella Maria Grosz</h1></a>
            </div>
            <nav class="nav">
                <ul>
                    <li><a href="/#hero" class={currentPath === '/' ? 'active' : ''}>Home</a></li>
                    <li><a href="/portfolio" class={currentPath === '/portfolio' ? 'active' : ''}>Portfolio</a></li>
                    <li><a href="/#about" class={currentPath === '/#about' ? 'active' : ''}>About</a></li>
                    <li><a href="/press" class={currentPath === '/press' ? 'active' : ''}>Press & Publications</a></li>
                    <li><a href="/exhibitions" class={currentPath === '/exhibitions' ? 'active' : ''}>Exhibitions</a></li>
                </ul>
            </nav>
            <a href="mailto:studio@ellamariagrosz.art?subject=Inquiry about Artwork" class="inquire-btn" aria-label="Inquire about artwork">Inquire</a>
        </div>
    </header>

    <main>
        <slot />
    </main>

    <footer id="contact" class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-brand">
                    <h3>Ella Maria Grosz</h3>
                    <p>&copy; 2023 All Rights Reserved</p>
                </div>

                <div class="footer-links">
                    <div class="social">
                        <span>Social</span>
                        <a href="https://instagram.com/ellamariagross" target="_blank" aria-label="Instagram">
                            <i class="fab fa-instagram"></i> Instagram
                        </a>
                        <a href="#" aria-label="Pinterest">
                            <i class="fab fa-pinterest-p"></i> Pinterest
                        </a>
                    </div>

                    <div class="contact-info">
                        <span>Studio</span>
                        <p>Unit 4, Netil House<br>1 Westgate St, London</p>
                        <a href="mailto:studio@ellamariagrosz.art">
                            <i class="far fa-envelope"></i> studio@ellamariagrosz.art
                        </a>
                    </div>
                </div>

                <div class="footer-actions">
                    <a href="mailto:studio@ellamariagrosz.art" class="email-circle-btn" aria-label="Send email">
                        <i class="fa-solid fa-paper-plane"></i>
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <script src="/script.js" is:inline></script>
</body>
</html>